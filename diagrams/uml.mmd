classDiagram
    class Pet {
        +String name
        +String species
        +int age
        +float weight
        +String activityLevel
        +List~String~ medicalNeeds
        +displayProfile() String
        +updateInfo() void
        +getCareRequirements() List~String~
    }

    class CareTask {
        +String taskName
        +String type
        +String priority
        +int duration
        +String frequency
        +DateTime dueTime
        +boolean completed
        +markComplete() void
        +markIncomplete() void
        +isOverdue() boolean
        +updateTask() void
        +Pet pet
    }

    class OwnerPreferences {
        +int availableTime
        +List<String> busyHours
        +List~Time~ preferredTaskTimes
        +int dailyTimeLimit
        +List~String~ taskPreferences
        +updateAvailability() void
        +updatePreferences() void
        +isAvailable(time: DateTime) boolean
    }

    class PetCareAssistant {
        +List~Pet~ pets
        +List~CareTask~ tasks
        +OwnerPreferences ownerPreferences
        +List~CareTask~ dailyPlan
        +generateDailyPlan() List~CareTask~
        +prioritizeTasks() List~CareTask~
        +explainPlan() String
        +rescheduleTasks() void
    }

    Pet "1" --> "*" CareTask : has
    PetCareAssistant "1" --> "*" Pet : manages
    PetCareAssistant "1" --> "*" CareTask : schedules
    PetCareAssistant "1" --> "1" OwnerPreferences : uses
